{
  "name": "agmap",
  "license": "0BSD",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev:lan": "expo start --host lan",
    "dev:tunnel": "EXPO_UNSTABLE_MCP_SERVER=1 expo start --dev-client --tunnel",
    "build:android": "expo run:android",
    "build:android:no-cache": "expo run:android --no-build-cache",
    "build:ios": "expo run:ios",
    "build:ios:no-cache": "expo run:ios --no-build-cache",
    "build:android:dev": "eas build --platform android --profile development",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:android:dev-local": "eas build --platform android --profile development --local",
    "build:ios:dev-local": "eas build --platform ios --profile development --local",
    "build:android:prod": "eas build --platform android --profile production",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:android:prod-local": "eas build --platform android --profile production --local",
    "build:ios:prod-local": "eas build --platform ios --profile production --local",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "test": "jest --watchAll",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "patch-package",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^14.1.0",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@turf/turf": "^7.3.4",
    "@types/proj4": "^2.5.6",
    "expo": "~53.0.27",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-camera": "~16.1.11",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-insights": "~0.9.3",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-router": "~5.1.11",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "proj4": "^2.20.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-toast-message": "^2.2.1",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "zustand": "^5.0.3",
    "zustand-expo-devtools": "^0.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.0.10",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "expo-mcp": "^0.2.4",
    "jest": "^29.2.1",
    "jest-expo": "~53.0.14",
    "patch-package": "^8.0.1",
    "prettier": "^3.5.3",
    "react-test-renderer": "19.0.0",
    "reactotron-react-native": "^5.1.12",
    "typescript": "~5.8.3"
  }
}
